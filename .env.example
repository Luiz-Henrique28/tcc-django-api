# ==============================================================================
# Django Configuration
# ==============================================================================

# Defina como False em produção
DJANGO_DEBUG=True

# Chave secreta (substitua por uma chave forte em produção)
DJANGO_SECRET_KEY=tcc-secret-key-for-development-only

# ==============================================================================
# Database Configuration (PostgreSQL)
# ==============================================================================

DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=tcc_catalog
DATABASE_USER=tcc_user
DATABASE_PASSWORD=tcc_password
